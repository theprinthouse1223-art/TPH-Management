generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./inventory.db"
}

model Product {
  id              Int      @id @default(autoincrement())
  barcode         String   @unique
  sku             String   @unique
  name            String
  category        String
  purchasePrice   Float
  sellingPrice    Float
  stock           Int
  minimumStock    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}